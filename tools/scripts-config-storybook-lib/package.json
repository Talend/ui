{
  "name": "@talend/scripts-config-storybook-lib",
  "description": "Storybook configuration utilities for Talend UI",
  "version": "6.1.1",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "Talend Frontend <frontend@talend.com>",
  "homepage": "https://github.com/Talend/ui/tree/master/tools/scripts-config-storybook-lib#readme",
  "bugs": {
    "url": "https://github.com/Talend/ui/issues"
  },
  "exports": {
    "./main": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    },
    "./preview": {
      "import": "./dist/preview.js",
      "types": "./dist/preview.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Talend/ui.git"
  },
  "scripts": {
    "build:lib": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint -o eslint-report.json --format json .",
    "update:msw": "npx msw init public/msw --save"
  },
  "files": [
    "dist",
    "public"
  ],
  "dependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-links": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@talend/bootstrap-theme": "^10.1.1",
    "@talend/design-system": "^12.1.1",
    "@talend/react-cmf": "^12.2.0",
    "@talend/icons": "^8.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "assert": "^2.1.0",
    "esbuild-plugin-react-virtualized": "^1.0.6",
    "i18next": "^23.16.8",
    "i18next-http-backend": "^1.4.5",
    "vite": "^7.3.1",
    "lodash": "^4.18.0",
    "msw": "2.12.7",
    "msw-storybook-addon": "^2.0.6",
    "querystring-es3": "^0.2.1",
    "react-i18next": "^13.5.0",
    "storybook": "^10.3.3",
    "util": "^0.12.5"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@talend/scripts-cmf": "^1.8.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28"
  },
  "publishConfig": {
    "access": "public"
  },
  "msw": {
    "workerDirectory": [
      "public",
      "public/msw"
    ]
  }
}
