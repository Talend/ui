{
  "name": "@talend/react-dataviz",
  "version": "8.1.1",
  "description": "Talend charts and visualization components",
  "main": "lib/index.js",
  "types": "./lib/index.d.ts",
  "module": "./lib-esm/index.js",
  "exports": {
    ".": {
      "import": "./lib-esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "license": "Apache-2.0",
  "scripts": {
    "build:lib": "talend-scripts build",
    "build:lib:esm": "talend-scripts build --esm",
    "build-storybook": "storybook build",
    "extract-i18n": "i18next-scanner --config i18next-scanner.config.js",
    "lint:js": "eslint -o eslint-report.json --format json .",
    "lint:css": "stylelint --formatter json -o stylelint-report.json \"**/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "start": "storybook dev -p 6006",
    "test": "cross-env TZ=UTC vitest run",
    "test:update": "cross-env TZ=UTC vitest run --update",
    "test:watch": "cross-env TZ=UTC vitest",
    "test:cov": "cross-env TZ=UTC vitest run --coverage --coverage.reporter=json-summary"
  },
  "keywords": [
    "react",
    "talend",
    "chart"
  ],
  "author": "Talend Frontend <frontend@talend.com>",
  "homepage": "https://github.com/Talend/ui/tree/master/packages/dataviz#readme",
  "bugs": {
    "url": "https://github.com/Talend/ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Talend/ui.git"
  },
  "dependencies": {
    "@talend/assets-api": "^2.1.1",
    "@talend/design-tokens": "^4.1.1",
    "@talend/react-components": "^18.1.1",
    "classnames": "^2.5.1",
    "d3": "^7.9.0",
    "date-fns": "^3.6.0",
    "geojson": "^0.5.0",
    "lodash": "^4.18.0",
    "recharts": "^2.15.4",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@talend/design-system": "^12.1.1",
    "@talend/eslint-config": "^14.1.2",
    "@talend/eslint-plugin": "^1.8.1",
    "@talend/icons": "^8.0.0",
    "@talend/locales-tui-components": "^16.0.1",
    "@talend/locales-tui-dataviz": "^3.0.1",
    "@talend/react-components": "^18.1.1",
    "@talend/scripts-config-babel": "^13.10.1",
    "@talend/scripts-config-react-webpack": "^17.1.1",
    "@talend/scripts-config-storybook-lib": "^6.1.1",
    "@talend/scripts-config-stylelint": "^5.0.0",
    "@talend/scripts-config-typescript": "^12.1.1",
    "@talend/scripts-core": "^20.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/classnames": "^2.3.4",
    "@types/d3": "^7.4.3",
    "@types/geojson": "^7946.0.16",
    "@types/lodash": "^4.17.24",
    "@types/node": "^6.14.13",
    "@types/react": "^18.3.28",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "stylelint": "^17.6.0",
    "cross-env": "^10.1.0",
    "i18next": "^23.16.8",
    "jsdom": "^28.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^13.5.0",
    "storybook": "^10.3.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "i18next": "^23.16.8",
    "react": "^18.3.1",
    "react-i18next": "^13.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
