{
  "name": "@talend/react-storybook-cmf",
  "description": "react-storybook-cmf library.",
  "version": "12.1.1",
  "license": "Apache-2.0",
  "author": "Talend Frontend <frontend@talend.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmfrancois/react-storybook-cmf"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "storybook",
    "addon"
  ],
  "scripts": {
    "build:lib": "talend-scripts build",
    "build:lib:esm": "talend-scripts build --esm",
    "vitest:run": "vitest run",
    "eslint": "eslint -o eslint-report.json --format json .",
    "vitest:update": "vitest run --update",
    "vitest:cov": "vitest run --coverage"
  },
  "main": "lib/index.js",
  "mainSrc": "src/index.js",
  "module": "./lib-esm/index.js",
  "exports": {
    ".": {
      "import": "./lib-esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "devDependencies": {
    "@talend/react-cmf": "^12.2.0",
    "@testing-library/react": "^14.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "redux-saga": "^1.4.2",
    "storybook": "^10.3.3"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "@talend/react-cmf": "^12.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "storybook": "^10.3.3",
    "redux-saga": "^1.4.2"
  }
}
