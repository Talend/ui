{
  "name": "@talend/react-storybook-cmf",
  "description": "react-storybook-cmf library.",
  "version": "12.1.0",
  "license": "Apache-2.0",
  "author": "Talend Frontend <frontend@talend.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmfrancois/react-storybook-cmf"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "storybook",
    "addon"
  ],
  "scripts": {
    "build:lib": "talend-scripts build",
    "build:lib:esm": "talend-scripts build --esm",
    "test": "talend-scripts test",
    "lint": "eslint .",
    "test:update": "talend-scripts test -u",
    "test:cov": "talend-scripts test --coverage --coverageReporters json-summary"
  },
  "main": "lib/index.js",
  "mainSrc": "src/index.js",
  "module": "./lib-esm/index.js",
  "exports": {
    ".": {
      "import": "./lib-esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "devDependencies": {
    "@talend/eslint-config": "^14.1.0",
    "@talend/eslint-plugin": "^1.8.0",
    "@talend/react-cmf": "^12.1.0",
    "@talend/scripts-core": "^18.0.0",
    "@talend/scripts-config-babel": "^13.10.0",
    "@testing-library/react": "^14.3.1",
    "eslint": "^9.39.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "redux-saga": "^1.4.2",
    "storybook": "^10.2.10"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "@talend/react-cmf": "^12.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "storybook": "^10.2.10",
    "redux-saga": "^1.4.2"
  }
}
