{
  "name": "@talend/react-storybook-cmf",
  "description": "react-storybook-cmf library.",
  "version": "12.1.1",
  "license": "Apache-2.0",
  "author": "Talend Frontend <frontend@talend.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmfrancois/react-storybook-cmf"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "storybook",
    "addon"
  ],
  "scripts": {
    "build:lib": "talend-scripts build",
    "build:lib:esm": "talend-scripts build --esm",
    "test": "vitest run",
    "lint": "eslint -o eslint-report.json --format json .",
    "test:update": "vitest run --update",
    "test:cov": "vitest run --coverage"
  },
  "main": "lib/index.js",
  "mainSrc": "src/index.js",
  "module": "./lib-esm/index.js",
  "exports": {
    ".": {
      "import": "./lib-esm/index.js",
      "require": "./lib/index.js"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@talend/eslint-config": "^14.1.3",
    "@talend/eslint-plugin": "^1.8.1",
    "@talend/react-cmf": "^12.2.1",
    "@talend/scripts-core": "^20.0.0",
    "@talend/scripts-config-babel": "^13.10.1",
    "@testing-library/react": "^14.3.1",
    "eslint": "^10.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "redux-saga": "^1.4.2",
    "storybook": "^10.3.5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "peerDependencies": {
    "@talend/react-cmf": "^12.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^7.2.9",
    "storybook": "^10.3.5",
    "redux-saga": "^1.4.2"
  }
}
