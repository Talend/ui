{
  "name": "@talend/storybook-docs",
  "version": "3.1.1",
  "description": "Talend Storybook Docs component library",
  "main": "lib/index.js",
  "module": "./lib-esm/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build:styles": "webpack --config webpack.custom.js --mode=production",
    "build:lib": "talend-scripts build && npm run build:styles",
    "build:lib:esm": "talend-scripts build --esm",
    "start": "npm run storybook",
    "lint:js": "eslint -o eslint-report.json --format json .",
    "lint:css": "stylelint --formatter json -o stylelint-report.json \"**/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "test": "echo no test",
    "storybook": "storybook dev -p 6106",
    "build-storybook": "storybook build --docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Talend/ui.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/Talend/ui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@algolia/autocomplete-js": "^1.19.8",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/react": "^10.3.5",
    "@talend/design-tokens": "^4.1.2",
    "algoliasearch": "^4.27.0",
    "classnames": "^2.5.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@figma/rest-api-spec": "^0.36.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@talend/eslint-config": "^14.1.3",
    "@talend/eslint-plugin": "^1.8.1",
    "@talend/scripts-config-babel": "^13.10.1",
    "@talend/scripts-config-stylelint": "^5.0.0",
    "@talend/scripts-config-typescript": "^12.1.1",
    "@talend/scripts-core": "^20.0.0",
    "@types/node": "^6.14.13",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "css-loader": "^7.1.4",
    "eslint": "^10.2.1",
    "stylelint": "^17.9.1",
    "mini-css-extract-plugin": "^2.10.2",
    "postcss-loader": "^8.2.1",
    "resolve-url-loader": "^5.0.0",
    "storybook": "^10.3.5",
    "sass": "^1.99.0",
    "sass-loader": "^14.2.1",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1"
  }
}
